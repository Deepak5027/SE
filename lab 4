          </Card>
          <Card className="p-4">
            <p className="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2" style={sans}>Legend</p>
            <div className="space-y-2 text-xs" style={sans}>
              <div className="flex items-center gap-2"><div className="w-8 h-4 rounded-full border-2 border-primary bg-primary/10" /><span>Terminal</span></div>
              <div className="flex items-center gap-2"><div className="w-8 h-4 rounded border-2 border-border bg-card" /><span>Process</span></div>
              <div className="flex items-center gap-2"><div className="w-8 h-4 border-2 border-violet-400 bg-violet-50" style={{ clipPath: "polygon(8% 0%,100% 0%,92% 100%,0% 100%)" }} /><span>I/O</span></div>
              <div className="flex items-center gap-2"><div className="w-8 h-4 bg-blue-100 border-2 border-blue-400" style={{ clipPath: "polygon(50% 0%,100% 50%,50% 100%,0% 50%)" }} /><span>Decision</span></div>
            </div>
          </Card>
        </div>
      </div>
    </div>
  );
}
