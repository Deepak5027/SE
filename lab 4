import { useState } from "react";
import { ChevronLeft, ChevronRight, ArrowRight, ArrowLeft, CheckCircle2, Circle, Clock, GitBranch, GitMerge, GitPullRequest, Package, Server, Terminal, Database, Globe, Layers, Users, BookOpen, BarChart2, Shield, Cpu, Zap, Truck, ShoppingCart, GraduationCap, Library, Lock, Code } from "lucide-react";

/* ─────────── shared helpers ─────────── */
const mono = { fontFamily: "'JetBrains Mono', monospace" };
const sans = { fontFamily: "'Inter', sans-serif" };

function Badge({ color, children }: { color: string; children: React.ReactNode }) {
  return (
    <span className={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${color}`} style={sans}>
      {children}
    </span>
  );
}

function Card({ children, className = "" }: { children: React.ReactNode; className?: string }) {
  return (
    <div className={`bg-card border border-border rounded-xl shadow-sm ${className}`}>
      {children}
    </div>
  );
}
/* ─────────── TASK 4: String Length Flowchart ─────────── */
function FlowBox({ children, type = "process", color = "bg-card" }: { children: React.ReactNode; type?: "terminal" | "process" | "decision" | "io"; color?: string }) {
  if (type === "terminal") return <div className={`${color} border-2 border-primary rounded-full px-6 py-2 text-sm font-semibold text-center`} style={sans}>{children}</div>;
  if (type === "decision") return (
    <div className="relative w-44 h-12 flex items-center justify-center">
      <div className="absolute inset-0" style={{ clipPath: "polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%)", background: "#dbeafe", border: "2px solid #3b82f6" }} />
      <span className="relative text-xs font-medium text-blue-800 text-center px-2" style={sans}>{children}</span>
    </div>
  );
  if (type === "io") return <div className={`${color} border-2 border-violet-400 px-5 py-2 text-sm text-center`} style={{ ...sans, clipPath: "polygon(8% 0%, 100% 0%, 92% 100%, 0% 100%)" }}>{children}</div>;
  return <div className={`${color} border-2 border-border px-5 py-2.5 rounded-md text-sm text-center shadow-sm`} style={sans}>{children}</div>;
}

function Arrow({ label }: { label?: string }) {
  return (
    <div className="flex flex-col items-center my-1">
      {label && <span className="text-xs text-muted-foreground mb-1" style={sans}>{label}</span>}
      <div className="flex flex-col items-center"><div className="w-px h-5 bg-foreground/30" /><div className="w-0 h-0 border-l-4 border-r-4 border-t-6 border-l-transparent border-r-transparent border-t-foreground/30" style={{ borderTopWidth: 7 }} /></div>
    </div>
  );
}

function Task4() {
  const [input, setInput] = useState("Hello World");
  const len = input.length;
  return (
    <div className="p-8 max-w-3xl mx-auto">
      <h2 className="text-xl font-semibold mb-1" style={sans}>String Length — Flowchart</h2>
      <p className="text-sm text-muted-foreground mb-6" style={sans}>Flowchart to display total number of characters in a string.</p>
      <div className="flex gap-8">
        <div className="flex flex-col items-center gap-0 flex-1">
          <FlowBox type="terminal" color="bg-primary/10">START</FlowBox>
          <Arrow />
          <FlowBox type="io" color="bg-violet-50">Input: string S</FlowBox>
          <Arrow />
          <FlowBox>Initialize length = 0</FlowBox>
          <Arrow />
          <FlowBox>i = 0</FlowBox>
          <Arrow />
          <FlowBox type="decision">S[i] ≠ null?</FlowBox>
          <div className="flex items-start gap-6 mt-1">
            <div className="flex flex-col items-center">
              <span className="text-xs text-emerald-600 font-medium mb-1" style={sans}>Yes</span>
              <Arrow />
