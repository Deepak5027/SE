        </div>

        <div className="w-56 space-y-4">
          <Card className="p-4">
            <p className="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2" style={sans}>Live Demo</p>
            <input value={input} onChange={e => setInput(e.target.value)} className="w-full bg-secondary border border-border rounded-lg px-3 py-2 text-sm mb-3" placeholder="Enter string..." style={sans} />
            <div className="bg-secondary rounded-lg p-3 text-center">
              <p className="text-xs text-muted-foreground mb-1" style={sans}>Length</p>
