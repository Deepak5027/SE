/* ─────────── TASK 8: Cyclomatic Complexity ─────────── */
function Task8() {
  const [E, setE] = useState(17);
  const [N, setN] = useState(13);
  const [P, setP] = useState(5);
  const v1 = E - N + 2;
  const v2 = E - N + P;
  return (
    <div className="p-8 max-w-3xl mx-auto">
      <h2 className="text-xl font-semibold mb-1" style={sans}>Cyclomatic Complexity Calculator</h2>
      <p className="text-sm text-muted-foreground mb-6" style={sans}>V(G) = E − N + 2 &nbsp;|&nbsp; V(G) = E − N + P</p>

      <div className="grid grid-cols-2 gap-6">
        <Card className="p-5">
          <p className="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-4" style={sans}>Graph Parameters</p>
          <div className="space-y-4">
            {[{ label: "Edges (E)", val: E, set: setE, color: "text-blue-600" }, { label: "Nodes (N)", val: N, set: setN, color: "text-violet-600" }, { label: "Predicate Nodes (P)", val: P, set: setP, color: "text-amber-600" }].map(({ label, val, set, color }) => (
              <div key={label}>
                <div className="flex justify-between mb-1"><label className="text-sm" style={sans}>{label}</label><span className={`font-bold text-sm ${color}`} style={mono}>{val}</span></div>
                <input type="range" min={1} max={30} value={val} onChange={e => set(Number(e.target.value))} className="w-full accent-primary" />
              </div>
            ))}
          </div>
        </Card>

        <div className="space-y-4">
          <Card className="p-5">
            <p className="text-xs font-semibold text-muted-foreground uppercase mb-3" style={sans}>Formula 1: V(G) = E − N + 2</p>
            <div className="bg-secondary rounded-lg p-4 text-center mb-3">
              <p className="text-xs text-muted-foreground mb-1" style={mono}>{E} − {N} + 2 = {v1}</p>
              <p className="text-4xl font-bold text-primary" style={mono}>{v1}</p>
            </div>
            <div className={`text-xs px-3 py-1.5 rounded-full text-center ${v1 <= 10 ? "bg-emerald-100 text-emerald-700" : v1 <= 20 ? "bg-amber-100 text-amber-700" : "bg-red-100 text-red-700"}`} style={sans}>
