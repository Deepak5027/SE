            <div className="bg-secondary rounded-lg p-4 text-center mb-3">
              <p className="text-xs text-muted-foreground mb-1" style={mono}>{E} − {N} + {P} = {v2}</p>
              <p className="text-4xl font-bold text-violet-600" style={mono}>{v2}</p>
            </div>
          </Card>

          <Card className="p-4">
            <p className="text-xs font-semibold text-muted-foreground uppercase mb-2" style={sans}>Scale Reference</p>
            <div className="space-y-1 text-xs" style={sans}>
              {[["1–10", "Simple, low risk", "bg-emerald-400"], ["11–20", "Moderate complexity", "bg-amber-400"], ["21–50", "High complexity", "bg-orange-500"], ["50+", "Very high risk", "bg-red-500"]].map(([r, l, c]) => (
